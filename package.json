{
  "name": "video-converter",
  "version": "1.0.0",
  "description": "Cross-platform video converter based on FFmpeg",
  "private": true,
  "workspaces": [
    "packages/*"
  ],
  "allowScripts": true,
  "scripts": {
    "dev:desktop": "npm run dev -w @video-converter/desktop",
    "dev:mobile": "npm run start -w @video-converter/mobile",
    "build:desktop": "npm run build -w @video-converter/desktop",
    "build:shared": "npm run build -w @video-converter/shared"
  },
  "devDependencies": {
    "typescript": "^5.3.0"
  }
}
